[sub_resource type="Shader" id="Shader_hit"]
code = "shader_type canvas_item;
uniform bool hit = false;
void fragment() {
	vec4 tex = texture(TEXTURE, UV);
	if (hit) {
		COLOR = vec4(1.0, 1.0, 1.0, tex.a);
	} else {
		COLOR = tex;
	}
}
"

